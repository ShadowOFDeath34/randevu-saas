generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------
// ENUM TIPLERI
// -----------------------------------------------------------------

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
  closed
}

enum PaymentStatus {
  unpaid
  paid
  refunded
  failed
}

enum NotificationChannel {
  email
  sms
  whatsapp
  push
  system
}

enum NotificationStatus {
  pending
  sent
  failed
  delivered
}

enum CampaignStatus {
  draft
  sent
  scheduled
}

enum CampaignType {
  sms
  email
}

enum CustomerSegment {
  loyal
  at_risk
  new
  all
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  planId    String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  businessProfile    BusinessProfile?
  businessHours     BusinessHour[]
  staff             Staff[]
  services          Service[]
  customers         Customer[]
  bookings          Booking[]
  statusLogs        BookingStatusLog[]
  notificationTemplates NotificationTemplate[]
  notificationLogs  NotificationLog[]
  reviewRequests    ReviewRequest[]
  subscription      Subscription?
  auditLogs         AuditLog[]
  campaigns         Campaign[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String   @unique
  passwordHash String
  resetToken   String?  @unique
  resetTokenExpiry DateTime?
  role         String   @default("owner")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff            Staff?
  campaignsCreated Campaign[]
  auditLogs        AuditLog[]
  bookingStatusLogs BookingStatusLog[]
}

model BusinessProfile {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  businessName String
  phone        String?
  email        String?
  address      String?
  city         String?
  district     String?
  description  String?
  logoUrl      String?
  bookingSlug  String   @unique
  timezone     String   @default("Europe/Istanbul")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BusinessHour {
  id         String   @id @default(cuid())
  tenantId   String
  dayOfWeek  Int
  openTime   String?
  closeTime  String?
  isClosed   Boolean  @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek])
}

model Staff {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?  @unique
  fullName   String
  title      String?
  phone      String?
  email      String?
  bio        String?
  avatarUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  workingHours StaffWorkingHour[]
  services  StaffService[]
  bookings  Booking[]

  @@unique([tenantId, fullName])
  @@index([tenantId, isActive])
}

model StaffWorkingHour {
  id         String   @id @default(cuid())
  tenantId   String
  staffId    String
  dayOfWeek  Int
  openTime   String?
  closeTime  String?
  isClosed   Boolean  @default(false)

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
}

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  price           Float?
  currency        String   @default("TRY")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff   StaffService[]
  bookings Booking[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model StaffService {
  id        String @id @default(cuid())
  tenantId  String
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

model Customer {
  id                String           @id @default(cuid())
  tenantId          String
  fullName          String
  phone             String
  email             String?
  notes             String?
  noShowCount       Int              @default(0)
  totalBookings     Int              @default(0)
  noShowProbability Float?
  lastVisitDate     DateTime?
  customerSegment   CustomerSegment? @default(new)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]
  notificationLogs NotificationLog[]
  reviewRequests ReviewRequest[]

  @@unique([tenantId, phone])
  @@index([tenantId, createdAt])
  @@index([tenantId, customerSegment])
  @@index([tenantId, lastVisitDate])
}

model Booking {
  id               String        @id @default(cuid())
  tenantId         String
  customerId       String
  serviceId        String
  staffId          String
  bookingDate      String
  startTime        String
  endTime          String
  status           BookingStatus   @default(pending)
  paymentStatus    PaymentStatus   @default(unpaid)
  paymentReference String?
  source           String          @default("public")
  notes            String?
  confirmationCode String          @unique @default(cuid())
  deletedAt        DateTime?       // Soft delete alanı
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff            Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  statusLogs       BookingStatusLog[]
  notificationLogs NotificationLog[]
  reminders        BookingReminder[]
  reviewRequest    ReviewRequest?

  @@unique([tenantId, staffId, bookingDate, startTime])
  @@index([tenantId, bookingDate])
  @@index([status, bookingDate])
  @@index([tenantId, customerId])
  @@index([tenantId, staffId])
  @@index([tenantId, status])
  @@index([bookingDate, status])
  @@index([deletedAt])
}

model BookingStatusLog {
  id              String         @id @default(cuid())
  tenantId        String
  bookingId       String
  oldStatus       BookingStatus?
  newStatus       BookingStatus
  changedByUserId String?
  changedAt       DateTime       @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, changedAt])
  @@index([tenantId, changedAt])
}

model NotificationTemplate {
  id       String              @id @default(cuid())
  tenantId String
  type     String
  channel  NotificationChannel @default(email)
  title    String
  body     String
  isActive Boolean             @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, channel])
}

model NotificationLog {
  id         String              @id @default(cuid())
  tenantId   String
  bookingId  String?
  customerId String?
  channel    NotificationChannel
  status     NotificationStatus
  payload    String?
  sentAt     DateTime            @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([sentAt, tenantId])
  @@index([tenantId, channel, status])
  @@index([tenantId, sentAt])
  @@index([customerId, sentAt])
}

model ReviewRequest {
  id          String              @id @default(cuid())
  tenantId    String
  bookingId    String              @unique
  customerId   String
  channel      NotificationChannel @default(email)
  status       String              @default("pending")
  rating       Int?                                    // 1-5 arası
  comment      String?                                 // Müşteri yorumu
  isPublished  Boolean             @default(false)     // Yayın durumu
  publishedAt  DateTime?                               // Yayınlanma tarihi
  requestedAt  DateTime            @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking  Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, isPublished])
  @@index([tenantId, rating])
}

model Plan {
  id                  String   @id @default(cuid())
  name                String
  price               Float
  billingPeriod       String
  maxStaff            Int      @default(1)
  maxBookingsPerMonth Int      @default(100)
  featuresJson        String   @default("[]")

  subscriptions Subscription[]
}

model Subscription {
  id                     String   @id @default(cuid())
  tenantId               String   @unique
  planId                 String
  status                 String   @default("trial")
  startDate              DateTime @default(now())
  endDate                DateTime?
  billingProvider        String?
  externalSubscriptionId String?
  trialEndsAt            DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([status, endDate])
}

model Invoice {
  id            String   @id @default(cuid())
  subscriptionId String
  tenantId      String
  amount        Float
  currency      String   @default("TRY")
  status        String   @default("pending")
  dueDate       DateTime
  paidAt        DateTime?
  invoiceNumber String   @unique
  description   String?

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([dueDate, status])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt, tenantId])
  @@index([action, entityType])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

// -----------------------------------------------------------------
// VERIFICATION CODES (Portal SMS Doğrulama)
// -----------------------------------------------------------------

model VerificationCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// -----------------------------------------------------------------
// FAZ 3 YENİ MODELLER: SMART MARKETING & KAMPANYALAR
// -----------------------------------------------------------------

model Campaign {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  targetSegment  CustomerSegment @default(all)
  type           CampaignType
  content        String
  aiGenerated    Boolean        @default(false)
  status         CampaignStatus @default(draft)
  sentAt         DateTime?
  sentCount      Int            @default(0)
  createdBy      String
  user           User           @relation(fields: [createdBy], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@index([tenantId, status])
  @@index([targetSegment, status])
}

// -----------------------------------------------------------------
// BOOKING REMINDERS (Otomatik Hatırlatmalar)
// -----------------------------------------------------------------

model BookingReminder {
  id        String   @id @default(cuid())
  bookingId String
  type      String   // reminder_24h, reminder_1h
  channel   String   // sms, email
  sentAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, type])
  @@index([sentAt])
}
