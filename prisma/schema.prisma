generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------
// ENUM TIPLERI
// -----------------------------------------------------------------

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
  closed
}

enum PaymentStatus {
  unpaid
  paid
  refunded
  failed
}

enum NotificationChannel {
  email
  sms
  whatsapp
  push
  system
}

enum NotificationStatus {
  pending
  sent
  failed
  delivered
}

enum CampaignStatus {
  draft
  sent
  scheduled
}

enum CampaignType {
  sms
  email
}

enum CustomerSegment {
  loyal
  at_risk
  new
  all
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  planId    String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  businessProfile       BusinessProfile?
  businessHours         BusinessHour[]
  staff                 Staff[]
  services              Service[]
  customers             Customer[]
  bookings              Booking[]
  statusLogs            BookingStatusLog[]
  notificationTemplates NotificationTemplate[]
  notificationLogs      NotificationLog[]
  reviewRequests        ReviewRequest[]
  subscription          Subscription?
  auditLogs             AuditLog[]
  campaigns             Campaign[]
  campaignTriggers      CampaignTrigger[]
  loyaltyConfig         LoyaltyConfig?
  DynamicPricingConfig  DynamicPricingConfig?
  DynamicPricingRule    DynamicPricingRule[]
  ServicePriceHistory   ServicePriceHistory[]
  PricingAnalytics      PricingAnalytics[]
  branches              Branch[]
}

model User {
  id               String    @id @default(cuid())
  tenantId         String
  name             String
  email            String    @unique
  passwordHash     String
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  role             String    @default("owner")
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff             Staff?
  campaignsCreated  Campaign[]
  auditLogs         AuditLog[]
  bookingStatusLogs BookingStatusLog[]
  branchPermissions BranchPermission[]
}

model BusinessProfile {
  id           String  @id @default(cuid())
  tenantId     String  @unique
  businessName String
  phone        String?
  email        String?
  address      String?
  city         String?
  district     String?
  description  String?
  logoUrl      String?
  bookingSlug  String  @unique
  timezone     String  @default("Europe/Istanbul")

  // Randevu ayarları
  bufferTimeMinutes       Int     @default(0) // Randevular arası hazırlık süresi (dakika)
  cancellationPolicyHours Int     @default(24) // İptal için minimum önceden bildirim (saat)
  allowOnlineBooking      Boolean @default(true) // Online randevu alınabilir mi?
  maxAdvanceBookingDays   Int     @default(30) // Maksimum kaç gün sonrasına randevu alınabilir
  minAdvanceBookingHours  Int     @default(1) // Minimum kaç saat önceden randevu alınabilir

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BusinessHour {
  id        String  @id @default(cuid())
  tenantId  String
  dayOfWeek Int
  openTime  String?
  closeTime String?
  isClosed  Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek])
}

model Staff {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?  @unique
  fullName  String
  title     String?
  phone     String?
  email     String?
  bio       String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  workingHours      StaffWorkingHour[]
  services          StaffService[]
  bookings          Booking[]
  branchAssignments StaffBranchAssignment[]
  Branch            Branch?                 @relation(fields: [branchId], references: [id])
  branchId          String?

  @@unique([tenantId, fullName])
  @@index([tenantId, isActive])
  @@index([tenantId])
  @@index([email])
}

model StaffWorkingHour {
  id        String  @id @default(cuid())
  tenantId  String
  staffId   String
  dayOfWeek Int
  openTime  String?
  closeTime String?
  isClosed  Boolean @default(false)

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
}

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  price           Float?
  currency        String   @default("TRY")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff               StaffService[]
  bookings            Booking[]
  ServicePriceHistory ServicePriceHistory[]
  branchServices      BranchService[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@index([tenantId])
}

model StaffService {
  id        String @id @default(cuid())
  tenantId  String
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

model Customer {
  id                String           @id @default(cuid())
  tenantId          String
  fullName          String
  phone             String
  email             String?
  notes             String?
  noShowCount       Int              @default(0)
  totalBookings     Int              @default(0)
  noShowProbability Float?
  lastVisitDate     DateTime?
  customerSegment   CustomerSegment? @default(new)

  // Loyalty & Rewards
  loyaltyPoints     Int         @default(0)
  loyaltyTier       LoyaltyTier @default(BRONZE)
  totalPointsEarned Int         @default(0)
  referralCode      String?     @unique
  referredBy        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings            Booking[]
  notificationLogs    NotificationLog[]
  reviewRequests      ReviewRequest[]
  loyaltyTransactions LoyaltyTransaction[]
  rewardRedemptions   RewardRedemption[]
  referralsMade       Referral[]           @relation("Referrer")
  referralsReceived   Referral[]           @relation("Referred")

  @@unique([tenantId, phone])
  @@unique([tenantId, referralCode])
  @@index([tenantId, createdAt])
  @@index([tenantId, customerSegment])
  @@index([tenantId, lastVisitDate])
  @@index([tenantId, email])
  @@index([tenantId, loyaltyTier])
  @@index([tenantId, loyaltyPoints])
  @@index([tenantId])
  @@index([email])
}

// Loyalty System

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoyaltyTransactionType {
  EARNED_BOOKING
  EARNED_COMPLETION
  EARNED_REVIEW
  EARNED_REFERRAL
  EARNED_BIRTHDAY
  EARNED_BONUS
  REDEEMED_REWARD
  EXPIRED
  ADJUSTMENT
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  tenantId    String
  customerId  String
  customer    Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        LoyaltyTransactionType
  points      Int // Positive for earned, negative for redeemed
  description String
  bookingId   String?
  expiryDate  DateTime? // Points expiry (optional)
  createdAt   DateTime               @default(now())

  @@index([customerId, createdAt])
  @@index([tenantId, createdAt])
  @@index([type, createdAt])
}

model Referral {
  id            String    @id @default(cuid())
  tenantId      String
  referrerId    String
  referrer      Customer  @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId    String    @unique
  referred      Customer  @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  status        String    @default("pending") // pending, completed, rewarded
  pointsAwarded Int       @default(0)
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([referrerId, status])
  @@index([tenantId, createdAt])
}

model RewardRedemption {
  id         String    @id @default(cuid())
  tenantId   String
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rewardType String // discount_20, discount_50, free_service, free_addon
  pointsCost Int
  value      Float // Discount amount or service value
  status     String    @default("active") // active, used, expired
  usedAt     DateTime?
  expiryDate DateTime
  createdAt  DateTime  @default(now())

  @@index([customerId, status])
  @@index([tenantId, createdAt])
  @@index([status, expiryDate])
}

model LoyaltyConfig {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pointsPerBooking     Int      @default(10)
  pointsPerCompletion  Int      @default(50)
  pointsPerReview      Int      @default(25)
  pointsPerReferral    Int      @default(100)
  birthdayBonusPoints  Int      @default(200)
  silverThreshold      Int      @default(500)
  goldThreshold        Int      @default(1500)
  platinumThreshold    Int      @default(3000)
  pointsExpiryMonths   Int      @default(12)
  referralEnabled      Boolean  @default(true)
  tierDiscountBronze   Float    @default(0)
  tierDiscountSilver   Float    @default(5)
  tierDiscountGold     Float    @default(10)
  tierDiscountPlatinum Float    @default(15)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Booking {
  id               String        @id @default(cuid())
  tenantId         String
  branchId         String?
  customerId       String
  serviceId        String
  staffId          String
  bookingDate      String
  startTime        String
  endTime          String
  status           BookingStatus @default(pending)
  paymentStatus    PaymentStatus @default(unpaid)
  paymentReference String?
  source           String        @default("public")
  notes            String?
  confirmationCode String        @unique @default(cuid())
  deletedAt        DateTime? // Soft delete alanı
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer         Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service          Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff            Staff              @relation(fields: [staffId], references: [id], onDelete: Cascade)
  statusLogs       BookingStatusLog[]
  notificationLogs NotificationLog[]
  reminders        BookingReminder[]
  reviewRequest    ReviewRequest?

  @@unique([tenantId, staffId, bookingDate, startTime])
  @@index([tenantId, bookingDate])
  @@index([status, bookingDate])
  @@index([tenantId, customerId])
  @@index([tenantId, staffId])
  @@index([tenantId, status])
  @@index([bookingDate, status])
  @@index([deletedAt])
  @@index([customerId])
  @@index([status])
  @@index([branchId])
}

model BookingStatusLog {
  id              String         @id @default(cuid())
  tenantId        String
  bookingId       String
  oldStatus       BookingStatus?
  newStatus       BookingStatus
  changedByUserId String?
  changedAt       DateTime       @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, changedAt])
  @@index([tenantId, changedAt])
}

model NotificationTemplate {
  id       String              @id @default(cuid())
  tenantId String
  type     String
  channel  NotificationChannel @default(email)
  title    String
  body     String
  isActive Boolean             @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, channel])
}

model NotificationLog {
  id         String              @id @default(cuid())
  tenantId   String
  bookingId  String?
  customerId String?
  channel    NotificationChannel
  status     NotificationStatus
  payload    String?
  sentAt     DateTime            @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([sentAt, tenantId])
  @@index([tenantId, channel, status])
  @@index([tenantId, sentAt])
  @@index([customerId, sentAt])
}

model ReviewRequest {
  id          String              @id @default(cuid())
  tenantId    String
  bookingId   String              @unique
  customerId  String
  channel     NotificationChannel @default(email)
  status      String              @default("pending")
  rating      Int? // 1-5 arası
  comment     String? // Müşteri yorumu
  isPublished Boolean             @default(false) // Yayın durumu
  publishedAt DateTime? // Yayınlanma tarihi
  requestedAt DateTime            @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, isPublished])
  @@index([tenantId, rating])
}

model Plan {
  id                  String @id @default(cuid())
  name                String
  price               Float
  billingPeriod       String
  maxStaff            Int    @default(1)
  maxBookingsPerMonth Int    @default(100)
  featuresJson        String @default("[]")

  subscriptions Subscription[]
}

model Subscription {
  id                     String    @id @default(cuid())
  tenantId               String    @unique
  planId                 String
  status                 String    @default("trial")
  startDate              DateTime  @default(now())
  endDate                DateTime?
  billingProvider        String?
  externalSubscriptionId String?
  trialEndsAt            DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([status, endDate])
}

model Invoice {
  id             String    @id @default(cuid())
  subscriptionId String
  tenantId       String
  amount         Float
  currency       String    @default("TRY")
  status         String    @default("pending")
  dueDate        DateTime
  paidAt         DateTime?
  invoiceNumber  String    @unique
  description    String?

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([dueDate, status])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt, tenantId])
  @@index([action, entityType])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

// -----------------------------------------------------------------
// VERIFICATION CODES (Portal SMS Doğrulama)
// -----------------------------------------------------------------

model VerificationCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// -----------------------------------------------------------------
// FAZ 3 YENİ MODELLER: SMART MARKETING & KAMPANYALAR
// -----------------------------------------------------------------

model Campaign {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  targetSegment CustomerSegment @default(all)
  type          CampaignType
  content       String
  aiGenerated   Boolean         @default(false)
  status        CampaignStatus  @default(draft)
  sentAt        DateTime?
  sentCount     Int             @default(0)
  createdBy     String
  user          User            @relation(fields: [createdBy], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@index([tenantId, status])
  @@index([targetSegment, status])
}

// -----------------------------------------------------------------
// BOOKING REMINDERS (Otomatik Hatırlatmalar)
// -----------------------------------------------------------------

model BookingReminder {
  id        String   @id @default(cuid())
  bookingId String
  type      String // reminder_24h, reminder_1h
  channel   String // sms, email
  sentAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, type])
  @@index([sentAt])
}

// -----------------------------------------------------------------
// AUTOMATED CAMPAIGN TRIGGERS (Otomatik Kampanya Tetikleyicileri)
// -----------------------------------------------------------------

enum TriggerType {
  booking_confirmed
  booking_cancelled
  booking_no_show
  booking_completed
  appointment_reminder_24h
  appointment_reminder_2h
  customer_birthday
  customer_at_risk
  customer_inactive_30d
  customer_inactive_60d
}

enum TriggerAction {
  send_sms
  send_email
  send_whatsapp
  send_notification
}

enum TriggerStatus {
  active
  paused
  draft
}

model CampaignTrigger {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  triggerType     TriggerType
  action          TriggerAction
  templateId      String? // NotificationTemplate ID (optional)
  conditions      String? // JSON: { minBookingCount: 5, segment: "vip", etc. }
  delayMinutes    Int           @default(0) // Tetikleyicinin çalışması için bekleme süresi (0 = hemen)
  status          TriggerStatus @default(active)
  lastTriggeredAt DateTime?
  triggerCount    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // İlişki: Trigger tetiklendiğinde oluşturulan loglar
  logs TriggerExecutionLog[]

  @@index([tenantId, status])
  @@index([tenantId, triggerType])
  @@index([status, triggerType])
  @@index([tenantId, createdAt])
}

model TriggerExecutionLog {
  id           String          @id @default(cuid())
  triggerId    String
  trigger      CampaignTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  tenantId     String
  customerId   String?
  bookingId    String?
  status       String // success, failed, pending
  payload      String? // Gönderilen mesaj içeriği
  errorMessage String?
  executedAt   DateTime        @default(now())

  @@index([triggerId, executedAt])
  @@index([tenantId, executedAt])
  @@index([status, executedAt])
}

// -----------------------------------------------------------------
// PHASE 4: AI-POWERED DYNAMIC PRICING
// -----------------------------------------------------------------

enum PricingRuleType {
  SURGE_PEAK_HOURS // Yoğun saatlerde fiyat artışı
  DISCOUNT_OFF_PEAK // Boş saatlerde indirim
  LAST_MINUTE // Son dakika indirimi
  ADVANCE_BOOKING // Erken rezervasyon indirimi
  LOYALTY_BONUS // Sadakat müşterilerine özel fiyat
  STANDOUT // Popüler personel için ek ücret
}

enum PricingAdjustmentType {
  PERCENTAGE_INCREASE // Yüzde artış
  PERCENTAGE_DECREASE // Yüzde indirim
  FIXED_AMOUNT // Sabit tutar ekle/çıkar
  FIXED_PRICE // Sabit fiyat belirle
}

model DynamicPricingConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Genel ayarlar
  isEnabled            Boolean @default(false)
  minAdjustmentPercent Float   @default(-30) // Maksimum indirim %30
  maxAdjustmentPercent Float   @default(50) // Maksimum zam %50

  // AI/ML ayarları
  useAiOptimization Boolean   @default(true)
  aiModelVersion    String    @default("v1")
  lastTrainingDate  DateTime?

  // Otomatik kurallar
  autoSurgePricing    Boolean @default(true) // Yoğunluk otomatik artış
  autoOffPeakDiscount Boolean @default(true) // Boş saat otomatik indirim

  // Saat dilimi ayarları
  peakHoursStart String @default("17:00") // Akşam yoğunluğu başlangıç
  peakHoursEnd   String @default("20:00") // Akşam yoğunluğu bitiş
  lunchRushStart String @default("12:00") // Öğle yoğunluğu
  lunchRushEnd   String @default("14:00")

  // Eşik değerler
  highDemandThreshold Int @default(80) // %80 doluluk = yüksek talep
  lowDemandThreshold  Int @default(30) // %30 doluluk = düşük talep
  lastMinuteHours     Int @default(24) // Son 24 saat = son dakika
  advanceBookingDays  Int @default(7) // 7+ gün = erken rezervasyon

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DynamicPricingRule {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Temel bilgiler
  name        String
  description String?
  ruleType    PricingRuleType
  isActive    Boolean         @default(true)
  priority    Int             @default(0) // 0 = en düşük öncelik

  // Kurallar
  adjustmentType  PricingAdjustmentType
  adjustmentValue Float // Yüzde veya tutar

  // Zaman kısıtlamaları (opsiyonel)
  startDate  DateTime? // Belirli tarih aralığı
  endDate    DateTime?
  daysOfWeek Int[] // [1,2,3,4,5] = hafta içi
  startTime  String? // "09:00"
  endTime    String? // "12:00"

  // Doluluk eşikleri (opsiyonel)
  minOccupancy Int? // %30
  maxOccupancy Int? // %80

  // Hizmet ve personel filtreleri
  serviceIds String[] // Boş = tüm hizmetler
  staffIds   String[] // Boş = tüm personeller

  // Sadakat seviyesi kısıtlaması
  minLoyaltyTier LoyaltyTier? // GOLD üstü müşterilere özel

  // Kullanım limitleri
  maxUsesPerDay  Int? // Günde maksimum kaç randevu
  maxUsesPerWeek Int?
  totalUseCount  Int  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, ruleType])
  @@index([tenantId, priority])
}

model ServicePriceHistory {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Fiyat bilgileri
  basePrice        Float
  adjustedPrice    Float
  adjustmentReason String?

  // Uygulanan kurallar
  appliedRules String[] // Rule ID'ler

  // Bağlam bilgisi
  bookingDate   String? // Hangi gün için
  startTime     String? // Hangi saat için
  occupancyRate Int? // O anki doluluk oranı

  createdAt DateTime @default(now())

  @@index([tenantId, serviceId, createdAt])
  @@index([tenantId, bookingDate])
}

model PricingAnalytics {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Tarih
  date String // "2025-01-15"
  hour Int // 0-23

  // Metrikler
  totalBookings Int   @default(0)
  totalRevenue  Float @default(0)
  avgPrice      Float @default(0)
  occupancyRate Int   @default(0)

  // AI önerileri
  aiRecommendedPrice Float?
  priceElasticity    Float? // Fiyat esnekliği (-1.0 ile 0 arası)
  demandScore        Int? // 0-100 arası talep skoru

  createdAt DateTime @default(now())

  @@unique([tenantId, date, hour])
  @@index([tenantId, date])
  @@index([tenantId, date, hour])
}

// -----------------------------------------------------------------
// PHASE 4: MULTI-LOCATION/BRANCH SUPPORT
// -----------------------------------------------------------------

enum BranchStatus {
  active
  inactive
  maintenance
}

enum BranchType {
  main // Ana şube
  satellite // Yan şube
  mobile // Mobil/pop-up
  franchise // Franchise
}

model Branch {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Temel bilgiler
  name   String
  code   String? // Şube kodu (örn: "IST-001")
  type   BranchType   @default(satellite)
  status BranchStatus @default(active)

  // İletişim
  phone      String?
  email      String?
  address    String?
  city       String?
  district   String?
  postalCode String?
  country    String  @default("TR")

  // Konum
  latitude  Float?
  longitude Float?

  // Çalışma saatleri (opsiyonel - tenant varsayılanını override eder)
  customHours Boolean @default(false)
  timezone    String  @default("Europe/Istanbul")

  // Kapasite
  maxConcurrentBookings Int @default(0) // 0 = sınırsız
  maxStaffCount         Int @default(0) // 0 = sınırsız

  // Özellikler
  hasParking       Boolean @default(false)
  isAccessible     Boolean @default(false) // Engelli erişimi
  hasWaitingArea   Boolean @default(true)
  hasOnlineBooking Boolean @default(true)

  // Online rezervasyon slug
  bookingSlug String? @unique
  bookingUrl  String?

  // İlişkiler
  staff            Staff[]
  services         BranchService[] // Hangi hizmetler bu şubede var
  bookings         Booking[]
  businessHours    BranchBusinessHour[]
  closedDates      BranchClosedDate[]
  staffAssignments StaffBranchAssignment[] // Personel-şube atamaları

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  BranchPermission BranchPermission[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([status])
  @@index([city])
}

// Şube çalışma saatleri
model BranchBusinessHour {
  id       String @id @default(cuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenantId String

  dayOfWeek Int // 0 = Pazar, 1 = Pazartesi
  openTime  String?
  closeTime String?
  isClosed  Boolean @default(false)

  // Öğle arası
  lunchBreakStart String?
  lunchBreakEnd   String?

  @@unique([branchId, dayOfWeek])
  @@index([branchId])
}

// Şube tatil günleri
model BranchClosedDate {
  id       String @id @default(cuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenantId String

  date      String // "2025-01-01"
  reason    String? // "Yılbaşı", "Bakım", vs.
  isFullDay Boolean @default(true)
  openTime  String? // Tam gün değilse
  closeTime String?

  createdAt DateTime @default(now())

  @@unique([branchId, date])
  @@index([branchId, date])
}

// Şube-Hizmet ilişkisi (hangi hizmet hangi şubede sunuluyor)
model BranchService {
  id        String  @id @default(cuid())
  tenantId  String
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Şube özel fiyat (opsiyonel)
  customPrice Float?

  // Şube özel süre (opsiyonel)
  customDurationMinutes Int?

  // Durum
  isAvailable Boolean @default(true)

  // Bu şubede bu hizmeti verebilen personeller
  staffIds String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, serviceId])
  @@index([tenantId, branchId])
  @@index([tenantId, serviceId])
}

// Personel-Şube atamaları (bir personel birden fazla şubede çalışabilir)
model StaffBranchAssignment {
  id       String @id @default(cuid())
  tenantId String
  staffId  String
  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Atama tipi
  isPrimary Boolean @default(true) // Ana şubesi mi?
  isActive  Boolean @default(true)

  // Çalışma günleri bu şubede (boş = her gün)
  workingDays Int[] // [1,2,3,4,5] = hafta içi

  // Saatler (opsiyonel)
  startTime String?
  endTime   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, branchId])
  @@index([tenantId, staffId])
  @@index([tenantId, branchId])
}

// Şube seviyesinde kullanıcı yetkileri
model BranchPermission {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Yetkiler
  canManageBookings Boolean @default(true)
  canManageStaff    Boolean @default(false)
  canManageServices Boolean @default(false)
  canViewAnalytics  Boolean @default(true)
  canManageSettings Boolean @default(false)
  canAccessKiosk    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, branchId])
  @@index([tenantId, userId])
  @@index([tenantId, branchId])
}
