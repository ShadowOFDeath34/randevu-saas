generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------
// ENUM TIPLERI
// -----------------------------------------------------------------

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
  closed
}

enum PaymentStatus {
  unpaid
  paid
  refunded
  failed
}

enum NotificationChannel {
  email
  sms
  whatsapp
  push
  system
}

enum NotificationStatus {
  pending
  sent
  failed
  delivered
}

enum CampaignStatus {
  draft
  sent
  scheduled
}

enum CampaignType {
  sms
  email
}

enum CustomerSegment {
  loyal
  at_risk
  new
  all
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  planId    String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Feature Flags
  aiFeaturesEnabled      Boolean @default(false)
  enableAdvancedRouting  Boolean @default(false)
  enableDynamicPricing   Boolean @default(false)

  users                 User[]
  businessProfile       BusinessProfile?
  businessHours         BusinessHour[]
  staff                 Staff[]
  services              Service[]
  customers             Customer[]
  bookings              Booking[]
  statusLogs            BookingStatusLog[]
  notificationTemplates NotificationTemplate[]
  notificationLogs      NotificationLog[]
  reviewRequests        ReviewRequest[]
  subscription          Subscription?
  auditLogs             AuditLog[]
  campaigns             Campaign[]
  campaignTriggers      CampaignTrigger[]
  loyaltyConfig         LoyaltyConfig?
  DynamicPricingConfig  DynamicPricingConfig?
  DynamicPricingRule    DynamicPricingRule[]
  ServicePriceHistory   ServicePriceHistory[]
  PricingAnalytics      PricingAnalytics[]
  branches              Branch[]
  staffPerformanceConfig StaffPerformanceConfig?
  bonusConfig         BonusConfig?
  staffBonusTargets    StaffBonusTarget[]
  staffBonuses         StaffBonus[]
  staffPerformanceLogs StaffPerformanceLog[]
  tenantBranding       TenantBranding?
  roles                Role[]
  apiKeys              ApiKey[]
  webhooks             Webhook[]
  notificationSettings NotificationSettings?
}

model User {
  id               String    @id @default(cuid())
  tenantId         String
  name             String
  email            String    @unique
  passwordHash     String
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  role             String    @default("owner")
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff             Staff?
  campaignsCreated  Campaign[]
  auditLogs         AuditLog[]
  bookingStatusLogs BookingStatusLog[]
  branchPermissions BranchPermission[]
  userRoles         UserRole[]
}

model BusinessProfile {
  id           String  @id @default(cuid())
  tenantId     String  @unique
  businessName String
  phone        String?
  email        String?
  address      String?
  city         String?
  district     String?
  description  String?
  logoUrl      String?
  bookingSlug  String  @unique
  timezone     String  @default("Europe/Istanbul")

  // Randevu ayarları
  bufferTimeMinutes       Int     @default(0) // Randevular arası hazırlık süresi (dakika)
  cancellationPolicyHours Int     @default(24) // İptal için minimum önceden bildirim (saat)
  allowOnlineBooking      Boolean @default(true) // Online randevu alınabilir mi?
  maxAdvanceBookingDays   Int     @default(30) // Maksimum kaç gün sonrasına randevu alınabilir
  minAdvanceBookingHours  Int     @default(1) // Minimum kaç saat önceden randevu alınabilir

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BusinessHour {
  id        String  @id @default(cuid())
  tenantId  String
  dayOfWeek Int
  openTime  String?
  closeTime String?
  isClosed  Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek])
}

model Staff {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?  @unique
  fullName  String
  title     String?
  phone     String?
  email     String?
  bio       String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  workingHours      StaffWorkingHour[]
  services          StaffService[]
  bookings          Booking[]
  branchAssignments StaffBranchAssignment[]
  Branch            Branch?                 @relation(fields: [branchId], references: [id])
  branchId          String?
  bonusTargets      StaffBonusTarget[]
  bonuses           StaffBonus[]
  performanceLogs   StaffPerformanceLog[]

  @@unique([tenantId, fullName])
  @@index([tenantId, isActive])
  @@index([tenantId])
  @@index([email])
}

model StaffWorkingHour {
  id        String  @id @default(cuid())
  tenantId  String
  staffId   String
  dayOfWeek Int
  openTime  String?
  closeTime String?
  isClosed  Boolean @default(false)

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
}

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  price           Float?
  currency        String   @default("TRY")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff               StaffService[]
  bookings            Booking[]
  ServicePriceHistory ServicePriceHistory[]
  branchServices      BranchService[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@index([tenantId])
}

model StaffService {
  id        String @id @default(cuid())
  tenantId  String
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

model Customer {
  id                String           @id @default(cuid())
  tenantId          String
  fullName          String
  phone             String
  email             String?
  notes             String?
  noShowCount       Int              @default(0)
  totalBookings     Int              @default(0)
  noShowProbability Float?
  lastVisitDate     DateTime?
  customerSegment   CustomerSegment? @default(new)

  // Loyalty & Rewards
  loyaltyPoints     Int         @default(0)
  loyaltyTier       LoyaltyTier @default(BRONZE)
  totalPointsEarned Int         @default(0)
  referralCode      String?     @unique
  referredBy        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings            Booking[]
  notificationLogs    NotificationLog[]
  reviewRequests      ReviewRequest[]
  loyaltyTransactions LoyaltyTransaction[]
  rewardRedemptions   RewardRedemption[]
  referralsMade       Referral[]           @relation("Referrer")
  referralsReceived   Referral[]           @relation("Referred")

  @@unique([tenantId, phone])
  @@unique([tenantId, referralCode])
  @@index([tenantId, createdAt])
  @@index([tenantId, customerSegment])
  @@index([tenantId, lastVisitDate])
  @@index([tenantId, email])
  @@index([tenantId, loyaltyTier])
  @@index([tenantId, loyaltyPoints])
  @@index([tenantId])
  @@index([email])
}

// Loyalty System

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoyaltyTransactionType {
  EARNED_BOOKING
  EARNED_COMPLETION
  EARNED_REVIEW
  EARNED_REFERRAL
  EARNED_BIRTHDAY
  EARNED_BONUS
  REDEEMED_REWARD
  EXPIRED
  ADJUSTMENT
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  tenantId    String
  customerId  String
  customer    Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        LoyaltyTransactionType
  points      Int // Positive for earned, negative for redeemed
  description String
  bookingId   String?
  expiryDate  DateTime? // Points expiry (optional)
  createdAt   DateTime               @default(now())

  @@index([customerId, createdAt])
  @@index([tenantId, createdAt])
  @@index([type, createdAt])
}

model Referral {
  id            String    @id @default(cuid())
  tenantId      String
  referrerId    String
  referrer      Customer  @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId    String    @unique
  referred      Customer  @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  status        String    @default("pending") // pending, completed, rewarded
  pointsAwarded Int       @default(0)
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([referrerId, status])
  @@index([tenantId, createdAt])
}

model RewardRedemption {
  id         String    @id @default(cuid())
  tenantId   String
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rewardType String // discount_20, discount_50, free_service, free_addon
  pointsCost Int
  value      Float // Discount amount or service value
  status     String    @default("active") // active, used, expired
  usedAt     DateTime?
  expiryDate DateTime
  createdAt  DateTime  @default(now())

  @@index([customerId, status])
  @@index([tenantId, createdAt])
  @@index([status, expiryDate])
}

model LoyaltyConfig {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pointsPerBooking     Int      @default(10)
  pointsPerCompletion  Int      @default(50)
  pointsPerReview      Int      @default(25)
  pointsPerReferral    Int      @default(100)
  birthdayBonusPoints  Int      @default(200)
  silverThreshold      Int      @default(500)
  goldThreshold        Int      @default(1500)
  platinumThreshold    Int      @default(3000)
  pointsExpiryMonths   Int      @default(12)
  referralEnabled      Boolean  @default(true)
  tierDiscountBronze   Float    @default(0)
  tierDiscountSilver   Float    @default(5)
  tierDiscountGold     Float    @default(10)
  tierDiscountPlatinum Float    @default(15)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Booking {
  id               String        @id @default(cuid())
  tenantId         String
  branchId         String?
  customerId       String
  serviceId        String
  staffId          String
  bookingDate      String
  startTime        String
  endTime          String
  status           BookingStatus @default(pending)
  paymentStatus    PaymentStatus @default(unpaid)
  paymentReference String?
  source           String        @default("public")
  notes            String?
  confirmationCode String        @unique @default(cuid())
  deletedAt        DateTime? // Soft delete alanı
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer         Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service          Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff            Staff              @relation(fields: [staffId], references: [id], onDelete: Cascade)
  statusLogs       BookingStatusLog[]
  notificationLogs NotificationLog[]
  reminders        BookingReminder[]
  reviewRequest    ReviewRequest?

  @@unique([tenantId, staffId, bookingDate, startTime])
  @@index([tenantId, bookingDate])
  @@index([status, bookingDate])
  @@index([tenantId, customerId])
  @@index([tenantId, staffId])
  @@index([tenantId, status])
  @@index([bookingDate, status])
  @@index([deletedAt])
  @@index([customerId])
  @@index([status])
  @@index([branchId])
}

model BookingStatusLog {
  id              String         @id @default(cuid())
  tenantId        String
  bookingId       String
  oldStatus       BookingStatus?
  newStatus       BookingStatus
  changedByUserId String?
  changedAt       DateTime       @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, changedAt])
  @@index([tenantId, changedAt])
}

model NotificationTemplate {
  id       String              @id @default(cuid())
  tenantId String
  type     String
  channel  NotificationChannel @default(email)
  title    String
  body     String
  isActive Boolean             @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, channel])
}

model NotificationLog {
  id         String              @id @default(cuid())
  tenantId   String
  bookingId  String?
  customerId String?
  channel    NotificationChannel
  status     NotificationStatus
  payload    String?
  sentAt     DateTime            @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([sentAt, tenantId])
  @@index([tenantId, channel, status])
  @@index([tenantId, sentAt])
  @@index([customerId, sentAt])
}

model ReviewRequest {
  id          String              @id @default(cuid())
  tenantId    String
  bookingId   String              @unique
  customerId  String
  channel     NotificationChannel @default(email)
  status      String              @default("pending")
  rating      Int? // 1-5 arası
  comment     String? // Müşteri yorumu
  isPublished Boolean             @default(false) // Yayın durumu
  publishedAt DateTime? // Yayınlanma tarihi
  requestedAt DateTime            @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, isPublished])
  @@index([tenantId, rating])
}

model Plan {
  id                  String @id @default(cuid())
  name                String
  price               Float
  billingPeriod       String
  maxStaff            Int    @default(1)
  maxBookingsPerMonth Int    @default(100)
  featuresJson        String @default("[]")

  subscriptions Subscription[]
}

model Subscription {
  id                     String    @id @default(cuid())
  tenantId               String    @unique
  planId                 String
  status                 String    @default("trial")
  startDate              DateTime  @default(now())
  endDate                DateTime?
  billingProvider        String?
  externalSubscriptionId String?
  trialEndsAt            DateTime?

  // iyzico alanlari
  iyzicoPaymentId        String?
  iyzicoConversationId   String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([status, endDate])
  @@index([iyzicoPaymentId])
}

model Invoice {
  id             String    @id @default(cuid())
  subscriptionId String
  tenantId       String
  amount         Float
  currency       String    @default("TRY")
  status         String    @default("pending")
  dueDate        DateTime
  paidAt         DateTime?
  invoiceNumber  String    @unique
  description    String?

  // iyzico alanlari
  iyzicoPaymentId String?

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([dueDate, status])
  @@index([iyzicoPaymentId])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt, tenantId])
  @@index([action, entityType])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

// -----------------------------------------------------------------
// VERIFICATION CODES (Portal SMS Doğrulama)
// -----------------------------------------------------------------

model VerificationCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// -----------------------------------------------------------------
// FAZ 3 YENİ MODELLER: SMART MARKETING & KAMPANYALAR
// -----------------------------------------------------------------

model Campaign {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  targetSegment CustomerSegment @default(all)
  type          CampaignType
  content       String
  aiGenerated   Boolean         @default(false)
  status        CampaignStatus  @default(draft)
  sentAt        DateTime?
  sentCount     Int             @default(0)
  createdBy     String
  user          User            @relation(fields: [createdBy], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@index([tenantId, status])
  @@index([targetSegment, status])
}

// -----------------------------------------------------------------
// BOOKING REMINDERS (Otomatik Hatırlatmalar)
// -----------------------------------------------------------------

model BookingReminder {
  id        String   @id @default(cuid())
  bookingId String
  type      String // reminder_24h, reminder_1h
  channel   String // sms, email
  sentAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, type])
  @@index([sentAt])
}

// -----------------------------------------------------------------
// AUTOMATED CAMPAIGN TRIGGERS (Otomatik Kampanya Tetikleyicileri)
// -----------------------------------------------------------------

enum TriggerType {
  booking_confirmed
  booking_cancelled
  booking_no_show
  booking_completed
  appointment_reminder_24h
  appointment_reminder_2h
  customer_birthday
  customer_at_risk
  customer_inactive_30d
  customer_inactive_60d
}

enum TriggerAction {
  send_sms
  send_email
  send_whatsapp
  send_notification
}

enum TriggerStatus {
  active
  paused
  draft
}

model CampaignTrigger {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  triggerType     TriggerType
  action          TriggerAction
  templateId      String? // NotificationTemplate ID (optional)
  conditions      String? // JSON: { minBookingCount: 5, segment: "vip", etc. }
  delayMinutes    Int           @default(0) // Tetikleyicinin çalışması için bekleme süresi (0 = hemen)
  status          TriggerStatus @default(active)
  lastTriggeredAt DateTime?
  triggerCount    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // İlişki: Trigger tetiklendiğinde oluşturulan loglar
  logs TriggerExecutionLog[]

  @@index([tenantId, status])
  @@index([tenantId, triggerType])
  @@index([status, triggerType])
  @@index([tenantId, createdAt])
}

model TriggerExecutionLog {
  id           String          @id @default(cuid())
  triggerId    String
  trigger      CampaignTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  tenantId     String
  customerId   String?
  bookingId    String?
  status       String // success, failed, pending
  payload      String? // Gönderilen mesaj içeriği
  errorMessage String?
  executedAt   DateTime        @default(now())

  @@index([triggerId, executedAt])
  @@index([tenantId, executedAt])
  @@index([status, executedAt])
}

// -----------------------------------------------------------------
// PHASE 4: AI-POWERED DYNAMIC PRICING
// -----------------------------------------------------------------

enum PricingRuleType {
  SURGE_PEAK_HOURS // Yoğun saatlerde fiyat artışı
  DISCOUNT_OFF_PEAK // Boş saatlerde indirim
  LAST_MINUTE // Son dakika indirimi
  ADVANCE_BOOKING // Erken rezervasyon indirimi
  LOYALTY_BONUS // Sadakat müşterilerine özel fiyat
  STANDOUT // Popüler personel için ek ücret
}

enum PricingAdjustmentType {
  PERCENTAGE_INCREASE // Yüzde artış
  PERCENTAGE_DECREASE // Yüzde indirim
  FIXED_AMOUNT // Sabit tutar ekle/çıkar
  FIXED_PRICE // Sabit fiyat belirle
}

model DynamicPricingConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Genel ayarlar
  isEnabled            Boolean @default(false)
  minAdjustmentPercent Float   @default(-30) // Maksimum indirim %30
  maxAdjustmentPercent Float   @default(50) // Maksimum zam %50

  // AI/ML ayarları
  useAiOptimization Boolean   @default(true)
  aiModelVersion    String    @default("v1")
  lastTrainingDate  DateTime?

  // Otomatik kurallar
  autoSurgePricing    Boolean @default(true) // Yoğunluk otomatik artış
  autoOffPeakDiscount Boolean @default(true) // Boş saat otomatik indirim

  // Saat dilimi ayarları
  peakHoursStart String @default("17:00") // Akşam yoğunluğu başlangıç
  peakHoursEnd   String @default("20:00") // Akşam yoğunluğu bitiş
  lunchRushStart String @default("12:00") // Öğle yoğunluğu
  lunchRushEnd   String @default("14:00")

  // Eşik değerler
  highDemandThreshold Int @default(80) // %80 doluluk = yüksek talep
  lowDemandThreshold  Int @default(30) // %30 doluluk = düşük talep
  lastMinuteHours     Int @default(24) // Son 24 saat = son dakika
  advanceBookingDays  Int @default(7) // 7+ gün = erken rezervasyon

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DynamicPricingRule {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Temel bilgiler
  name        String
  description String?
  ruleType    PricingRuleType
  isActive    Boolean         @default(true)
  priority    Int             @default(0) // 0 = en düşük öncelik

  // Kurallar
  adjustmentType  PricingAdjustmentType
  adjustmentValue Float // Yüzde veya tutar

  // Zaman kısıtlamaları (opsiyonel)
  startDate  DateTime? // Belirli tarih aralığı
  endDate    DateTime?
  daysOfWeek Int[] // [1,2,3,4,5] = hafta içi
  startTime  String? // "09:00"
  endTime    String? // "12:00"

  // Doluluk eşikleri (opsiyonel)
  minOccupancy Int? // %30
  maxOccupancy Int? // %80

  // Hizmet ve personel filtreleri
  serviceIds String[] // Boş = tüm hizmetler
  staffIds   String[] // Boş = tüm personeller

  // Sadakat seviyesi kısıtlaması
  minLoyaltyTier LoyaltyTier? // GOLD üstü müşterilere özel

  // Kullanım limitleri
  maxUsesPerDay  Int? // Günde maksimum kaç randevu
  maxUsesPerWeek Int?
  totalUseCount  Int  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, ruleType])
  @@index([tenantId, priority])
}

model ServicePriceHistory {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Fiyat bilgileri
  basePrice        Float
  adjustedPrice    Float
  adjustmentReason String?

  // Uygulanan kurallar
  appliedRules String[] // Rule ID'ler

  // Bağlam bilgisi
  bookingDate   String? // Hangi gün için
  startTime     String? // Hangi saat için
  occupancyRate Int? // O anki doluluk oranı

  createdAt DateTime @default(now())

  @@index([tenantId, serviceId, createdAt])
  @@index([tenantId, bookingDate])
}

model PricingAnalytics {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Tarih
  date String // "2025-01-15"
  hour Int // 0-23

  // Metrikler
  totalBookings Int   @default(0)
  totalRevenue  Float @default(0)
  avgPrice      Float @default(0)
  occupancyRate Int   @default(0)

  // AI önerileri
  aiRecommendedPrice Float?
  priceElasticity    Float? // Fiyat esnekliği (-1.0 ile 0 arası)
  demandScore        Int? // 0-100 arası talep skoru

  createdAt DateTime @default(now())

  @@unique([tenantId, date, hour])
  @@index([tenantId, date])
  @@index([tenantId, date, hour])
}

// -----------------------------------------------------------------
// PHASE 4: MULTI-LOCATION/BRANCH SUPPORT
// -----------------------------------------------------------------

enum BranchStatus {
  active
  inactive
  maintenance
}

enum BranchType {
  main // Ana şube
  satellite // Yan şube
  mobile // Mobil/pop-up
  franchise // Franchise
}

model Branch {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Temel bilgiler
  name   String
  code   String? // Şube kodu (örn: "IST-001")
  type   BranchType   @default(satellite)
  status BranchStatus @default(active)

  // İletişim
  phone      String?
  email      String?
  address    String?
  city       String?
  district   String?
  postalCode String?
  country    String  @default("TR")

  // Konum
  latitude  Float?
  longitude Float?

  // Çalışma saatleri (opsiyonel - tenant varsayılanını override eder)
  customHours Boolean @default(false)
  timezone    String  @default("Europe/Istanbul")

  // Kapasite
  maxConcurrentBookings Int @default(0) // 0 = sınırsız
  maxStaffCount         Int @default(0) // 0 = sınırsız

  // Özellikler
  hasParking       Boolean @default(false)
  isAccessible     Boolean @default(false) // Engelli erişimi
  hasWaitingArea   Boolean @default(true)
  hasOnlineBooking Boolean @default(true)

  // Online rezervasyon slug
  bookingSlug String? @unique
  bookingUrl  String?

  // İlişkiler
  staff            Staff[]
  services         BranchService[] // Hangi hizmetler bu şubede var
  bookings         Booking[]
  businessHours    BranchBusinessHour[]
  closedDates      BranchClosedDate[]
  staffAssignments StaffBranchAssignment[] // Personel-şube atamaları

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  BranchPermission BranchPermission[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([status])
  @@index([city])
}

// Şube çalışma saatleri
model BranchBusinessHour {
  id       String @id @default(cuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenantId String

  dayOfWeek Int // 0 = Pazar, 1 = Pazartesi
  openTime  String?
  closeTime String?
  isClosed  Boolean @default(false)

  // Öğle arası
  lunchBreakStart String?
  lunchBreakEnd   String?

  @@unique([branchId, dayOfWeek])
  @@index([branchId])
}

// Şube tatil günleri
model BranchClosedDate {
  id       String @id @default(cuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenantId String

  date      String // "2025-01-01"
  reason    String? // "Yılbaşı", "Bakım", vs.
  isFullDay Boolean @default(true)
  openTime  String? // Tam gün değilse
  closeTime String?

  createdAt DateTime @default(now())

  @@unique([branchId, date])
  @@index([branchId, date])
}

// Şube-Hizmet ilişkisi (hangi hizmet hangi şubede sunuluyor)
model BranchService {
  id        String  @id @default(cuid())
  tenantId  String
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Şube özel fiyat (opsiyonel)
  customPrice Float?

  // Şube özel süre (opsiyonel)
  customDurationMinutes Int?

  // Durum
  isAvailable Boolean @default(true)

  // Bu şubede bu hizmeti verebilen personeller
  staffIds String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, serviceId])
  @@index([tenantId, branchId])
  @@index([tenantId, serviceId])
}

// Personel-Şube atamaları (bir personel birden fazla şubede çalışabilir)
model StaffBranchAssignment {
  id       String @id @default(cuid())
  tenantId String
  staffId  String
  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Atama tipi
  isPrimary Boolean @default(true) // Ana şubesi mi?
  isActive  Boolean @default(true)

  // Çalışma günleri bu şubede (boş = her gün)
  workingDays Int[] // [1,2,3,4,5] = hafta içi

  // Saatler (opsiyonel)
  startTime String?
  endTime   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, branchId])
  @@index([tenantId, staffId])
  @@index([tenantId, branchId])
}

// Şube seviyesinde kullanıcı yetkileri
model BranchPermission {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Yetkiler
  canManageBookings Boolean @default(true)
  canManageStaff    Boolean @default(false)
  canManageServices Boolean @default(false)
  canViewAnalytics  Boolean @default(true)
  canManageSettings Boolean @default(false)
  canAccessKiosk    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, branchId])
  @@index([tenantId, userId])
  @@index([tenantId, branchId])
}

// -----------------------------------------------------------------
// PHASE 4: STAFF PERFORMANCE BONUS SYSTEM
// -----------------------------------------------------------------

enum BonusPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum BonusMetricType {
  BOOKING_COUNT      // Tamamlanan randevu sayısı
  REVENUE           // Toplam gelir
  CUSTOMER_RATING   // Müşteri değerlendirmesi
  UPSELL_RATE       // Ekstra satış oranı
  RETENTION_RATE    // Müşteri sadakati
  ATTENDANCE        // Devamlılık
}

enum BonusCalculationType {
  FIXED_AMOUNT      // Sabit tutar
  PERCENTAGE      // Gelirin yüzdesi
  TIERED          // Kademeli (hedeflere göre)
}

enum BonusStatus {
  PENDING      // Bekliyor
  CALCULATED   // Hesaplandı
  APPROVED     // Onaylandı
  PAID         // Ödendi
  CANCELLED    // İptal edildi
}

// Hedef yapılandırma şablonu
model StaffPerformanceConfig {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Genel ayarlar
  isEnabled       Boolean @default(false)
  defaultPeriod   BonusPeriod @default(MONTHLY)
  calculationDay  Int      @default(1) // Ayın hangi günü hesaplansın

  // Varsayılan prim oranları
  baseBonusPercentage Float @default(5) // Gelirin %5'i
  minBookingCount     Int   @default(50) // Minimum 50 randevu
  minCustomerRating   Float @default(4.0) // Minimum 4.0 puan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Prim sistemi genel yapılandırması
model BonusConfig {
  id        String @id @default(cuid())
  tenantId  String @unique
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  isEnabled           Boolean @default(true)
  defaultPeriod       String  @default("MONTHLY") // WEEKLY, MONTHLY, QUARTERLY
  calculationDay      Int     @default(1) // Ayın hangi günü hesaplama yapılacak
  baseBonusPercentage Float   @default(5) // Varsayılan prim yüzdesi
  minBookingCount     Int     @default(50) // Minimum randevu sayısı
  minCustomerRating   Float   @default(4.0) // Minimum müşteri puanı

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// Personel özel hedef ve prim yapılandırması
model StaffBonusTarget {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId  String
  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  // Hedef dönemi
  period    BonusPeriod
  year      Int
  month     Int?      // WEEKLY için null
  week      Int?      // MONTHLY/QUARTERLY için null
  quarter   Int?      // MONTHLY/WEEKLY için null

  // Hedefler
  targetBookingCount    Int?
  targetRevenue         Float?
  targetCustomerRating  Float?
  targetUpsellRate      Float?

  // Prim yapılandırması
  calculationType   BonusCalculationType @default(TIERED)
  baseAmount        Float                @default(0)
  percentageRate    Float                @default(0) // Yüzde hesaplama için

  // Kademeli prim yapılandırması (JSON)
  // [{ "min": 0, "max": 50, "bonus": 500 }, { "min": 51, "max": 100, "bonus": 1000 }]
  tierConfig        String?

  // Durum
  isActive          Boolean @default(true)
  isCustom          Boolean @default(false) // Varsayılan hedef yerine özel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hesaplanan primler
  bonuses StaffBonus[]

  @@unique([staffId, period, year, month, week])
  @@index([tenantId, staffId])
  @@index([tenantId, period, year])
}

// Hesaplanan prim kayıtları
model StaffBonus {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId         String
  staff           Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  targetId        String
  target          StaffBonusTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  // Dönem bilgisi
  period          BonusPeriod
  year            Int
  month           Int?
  week            Int?

  // Gerçekleşen metrikler
  actualBookingCount    Int
  actualRevenue         Float
  actualCustomerRating  Float
  actualUpsellRate      Float
  actualAttendanceRate  Float

  // Hesaplanan prim
  baseSalary            Float      @default(0) // Temel maaş (opsiyonel)
  calculatedBonus       Float
  bonusPercentage       Float      // Prim oranı (yüzde olarak)

  // Durum
  status                BonusStatus @default(PENDING)
  approvedBy            String?
  approvedAt            DateTime?
  paidAt                DateTime?
  paymentReference      String?

  // Notlar
  notes                 String?
  calculationBreakdown  String?    // JSON: Detaylı hesaplama

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, period, year, month, week])
  @@index([tenantId, period, year, month])
  @@index([tenantId, staffId])
  @@index([status])
}

// Günlük/haftalık performans kayıtları
model StaffPerformanceLog {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  // Tarih
  date        String   // "2025-01-15"

  // Günlük metrikler
  bookingsCompleted     Int      @default(0)
  bookingsCancelled     Int      @default(0)
  revenueGenerated      Float    @default(0)
  customersServed       Int      @default(0)
  averageRating         Float?
  upsellAmount          Float    @default(0)

  // Çalışma saatleri
  hoursWorked           Float?   @default(0)
  isPresent             Boolean  @default(true)

  createdAt DateTime @default(now())

  @@unique([staffId, date])
  @@index([tenantId, staffId, date])
  @@index([tenantId, date])
}

// -----------------------------------------------------------------
// PHASE 5: ENTERPRISE - WHITE-LABEL & CUSTOM BRANDING
// -----------------------------------------------------------------

model TenantBranding {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Logo & Assets
  logoUrl        String?
  logoDarkUrl    String? // Dark mode logo
  faviconUrl     String?
  loadingImageUrl String? // Loading spinner image

  // Colors (CSS variables)
  primaryColor   String @default("#4f46e5") // Indigo-600
  secondaryColor String @default("#7c3aed") // Violet-600
  accentColor    String @default("#06b6d4") // Cyan-500
  backgroundColor String @default("#ffffff")
  textColor      String @default("#1f2937")

  // Dark mode colors
  darkBackgroundColor String @default("#111827")
  darkTextColor       String @default("#f3f4f6")

  // Typography
  fontFamily     String @default("Inter, system-ui, sans-serif")
  headingFont    String?
  fontScale      String @default("100%") // 90%, 100%, 110%

  // Custom Domain
  customDomain   String? @unique
  domainVerified Boolean @default(false)
  sslStatus      String  @default("pending") // pending, active, expired

  // Email Template Customization
  emailLogoUrl      String?
  emailHeaderColor  String @default("#4f46e5")
  emailFooterText   String?
  emailFromName     String?
  emailFromAddress  String?
  emailReplyTo      String?

  // Portal Customization
  portalTitle       String @default("Randevu Portalı")
  portalSubtitle    String?
  customCss         String? @db.Text
  customHeadHtml    String? @db.Text
  customFooterHtml  String? @db.Text

  // Booking Page Customization
  bookingPageSlug   String? @unique
  bookingPageTitle  String @default("Randevu Al")
  bookingPageDescription String?
  showPoweredBy     Boolean @default(true)
  showTenantName    Boolean @default(true)

  // Social Links
  facebookUrl   String?
  instagramUrl  String?
  twitterUrl    String?
  linkedinUrl   String?
  websiteUrl    String?

  // Meta Tags
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImageUrl      String?

  // Active Themes
  themeMode     String @default("light") // light, dark, auto
  themeVariant  String @default("default") // default, modern, minimal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customDomain])
  @@index([bookingPageSlug])
}

// -----------------------------------------------------------------
// PHASE 5: ENTERPRISE - RBAC (ROLE-BASED ACCESS CONTROL)
// -----------------------------------------------------------------

enum RoleType {
  SYSTEM // System-defined roles (cannot be deleted)
  CUSTOM // User-defined custom roles
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        RoleType @default(CUSTOM)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  // Role color for UI
  color       String @default("#4f46e5")

  // Permissions (JSON array of permission strings)
  // ["bookings:read", "bookings:create", "bookings:update", "bookings:delete"]
  // ["staff:read", "staff:manage"]
  // ["customers:read", "customers:manage"]
  // ["services:read", "services:manage"]
  // ["analytics:read", "analytics:export"]
  // ["settings:read", "settings:manage"]
  // ["billing:read", "billing:manage"]
  // ["admin:full_access"]
  permissions String // JSON array

  // Auto-assign rules
  autoAssignNewUsers Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model UserRole {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  // Optional: Branch-specific role assignment
  branchId String?

  assignedAt  DateTime @default(now())
  assignedBy  String?  // User ID who assigned this role

  // Custom permissions override for this specific user
  customPermissions Json? // { "bookings:delete": false, "analytics:export": true }

  @@unique([userId, roleId, branchId])
  @@index([userId])
  @@index([roleId])
}

// Permission definitions (reference table)
model Permission {
  id          String @id @default(cuid())
  key         String @unique // "bookings:read"
  name        String // "Bookings - View"
  description String?
  category    String // "bookings", "staff", "customers", etc.

  // Display info
  icon        String? // Lucide icon name
  color       String? // Tailwind color class

  // Metadata
  isSystem     Boolean @default(true)
  requiresPlan String? // Which plan is required: "starter", "pro", "enterprise"

  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------
// PHASE 5: ENTERPRISE - API KEYS & RATE LIMITING
// -----------------------------------------------------------------

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model ApiKey {
  id          String @id @default(cuid())
  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Key info
  name        String  // "Mobile App Integration"
  description String?

  // The actual key (hashed storage)
  keyHash     String  @unique // SHA-256 hash
  keyPrefix   String  // First 8 chars for display: "ak_live_abc123..."

  // Status
  status      ApiKeyStatus @default(ACTIVE)
  expiresAt   DateTime?
  lastUsedAt  DateTime?

  // Permissions (subset of tenant permissions)
  permissions String? // JSON array: ["bookings:read", "customers:read"]
  allowedIps  String? // JSON array of allowed IPs ["192.168.1.0/24"]
  allowedOrigins String? // CORS origins

  // Rate limiting per key
  rateLimitPerMinute  Int @default(60)
  rateLimitPerHour    Int @default(1000)
  rateLimitPerDay     Int @default(10000)

  // Usage tracking
  usageCountTotal     Int @default(0)
  usageCountThisMonth Int @default(0)

  createdBy   String? // User ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  revokedAt   DateTime?
  revokedBy   String?
  revokeReason String?

  // Relations
  usageLogs ApiUsageLog[]

  @@index([tenantId, status])
  @@index([keyHash])
  @@index([status, expiresAt])
}

model ApiUsageLog {
  id         String   @id @default(cuid())
  tenantId   String
  apiKeyId   String
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  // Request info
  endpoint    String   // "/api/v1/bookings"
  method      String   // "GET", "POST", etc.
  statusCode  Int      // HTTP response code

  // Request metadata
  ipAddress   String?
  userAgent   String?
  requestTime DateTime @default(now())
  responseTimeMs Int? // Response time in milliseconds

  // Request/Response size
  requestSize  Int?
  responseSize Int?

  // Error tracking
  errorType    String?
  errorMessage String?

  @@index([apiKeyId, requestTime])
  @@index([tenantId, requestTime])
  @@index([endpoint, requestTime])
}

// -----------------------------------------------------------------
// PHASE 5: ENTERPRISE - WEBHOOKS
// -----------------------------------------------------------------

enum WebhookEvent {
  // Booking events
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  BOOKING_UPDATED
  BOOKING_NO_SHOW

  // Customer events
  CUSTOMER_CREATED
  CUSTOMER_UPDATED

  // Payment events
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  PAYMENT_REFUNDED

  // Staff events
  STAFF_AVAILABILITY_CHANGED

  // System events
  TEST // Test webhook
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

model Webhook {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Configuration
  name        String
  url         String  // HTTPS endpoint
  description String?
  status      WebhookStatus @default(ACTIVE)

  // Events to subscribe
  events      String // JSON array of WebhookEvent values

  // Security
  secret      String? // Webhook signing secret (for HMAC verification)
  signatureHeader String @default("X-Webhook-Signature")

  // Retry configuration
  maxRetries        Int @default(3)
  retryIntervalSec  Int @default(60) // Exponential backoff base

  // Filtering
  filterBranchId    String? // Only events from this branch
  filterServiceId   String? // Only events for this service

  // Metadata
  createdBy String? // User ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  deliveries WebhookDelivery[]

  @@index([tenantId, status])
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

model WebhookDelivery {
  id        String @id @default(cuid())
  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  tenantId  String

  // Event data
  eventType   WebhookEvent
  eventId     String // Unique event ID (for idempotency)
  payload     String @db.Text // JSON payload

  // Delivery tracking
  status          WebhookDeliveryStatus @default(PENDING)
  attemptCount    Int @default(0)
  nextRetryAt     DateTime?

  // HTTP details
  requestHeaders  String? // JSON
  requestBody     String? // JSON
  responseStatus  Int?
  responseHeaders String?
  responseBody    String? @db.Text

  // Error details
  errorCode       String?
  errorMessage    String?

  // Timestamps
  firstAttemptAt  DateTime?
  lastAttemptAt   DateTime?
  deliveredAt     DateTime?

  // Performance
  responseTimeMs  Int?

  createdAt DateTime @default(now())

  @@index([webhookId, status])
  @@index([tenantId, createdAt])
  @@index([eventId])
  @@index([status, nextRetryAt]) // For retry scheduler
}

// -----------------------------------------------------------------
// NOTIFICATION SETTINGS (Tenant Notification Preferences)
// -----------------------------------------------------------------

model NotificationSettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // SMS Hatırlatmalar
  smsReminders24h Boolean @default(true) // 24 saat önce SMS hatırlatma
  smsReminders1h  Boolean @default(true) // 1 saat önce SMS hatırlatma

  // Email Hatırlatmalar
  emailReminders24h Boolean @default(true) // 24 saat önce email hatırlatma
  emailReminders1h  Boolean @default(true) // 1 saat önce email hatırlatma

  // Booking Notifications (İşletmeye bildirimler)
  notifyNewBooking     Boolean @default(true) // Yeni randevu bildirimi
  notifyCancellation   Boolean @default(true) // İptal bildirimi
  notifyNoShow         Boolean @default(true) // Gelmedi bildirimi
  notifyReschedule     Boolean @default(true) // Değişiklik bildirimi

  // Channel preferences by event type
  bookingConfirmationChannel NotificationChannel @default(email) // sms, email, whatsapp
  bookingReminderChannel     NotificationChannel @default(sms)  // sms, email
  marketingChannel           NotificationChannel @default(email) // sms, email, whatsapp

  // Daily notification limits (spam prevention)
  dailySMSLimit    Int @default(100)
  dailyEmailLimit  Int @default(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------
// NOTIFICATION COST TRACKING
// -----------------------------------------------------------------

model NotificationCostLog {
  id        String              @id @default(cuid())
  tenantId  String
  channel   NotificationChannel
  segments  Int                 @default(1) // SMS segment sayısı
  cost      Float               @default(0) // TL cinsinden
  sentAt    DateTime            @default(now())

  @@index([tenantId, sentAt])
  @@index([tenantId, channel])
}
